import streamlit as st

st.set_page_config(page_title="Med IA", page_icon="🏥")

st.title("🏥 Med IA")
st.write("💬 Descreva o que você está sentindo:")

# ===== MEMÓRIA =====
if "chat" not in st.session_state:
    st.session_state.chat = []

if "memoria" not in st.session_state:
    st.session_state.memoria = {
        "sintomas": set(),
        "perguntas": [],
        "interacoes": 0,
        "finalizado": False
    }

memoria = st.session_state.memoria

# ===== NORMALIZAÇÃO =====
def normalizar(texto):
    texto = texto.lower()
    mapa = {
        "tô": "estou",
        "tá": "está",
        "sem ar": "falta de ar",
        "peito doendo": "dor no peito",
        "cabeça": "dor de cabeça"
    }
    for k, v in mapa.items():
        texto = texto.replace(k, v)
    return texto

# ===== DETECTAR SINTOMAS =====
def detectar(texto):
    texto = normalizar(texto)

    sintomas_lista = [
        "dor no peito", "falta de ar", "febre", "tosse",
        "tontura", "desmaio", "náusea", "vomito",
        "diarreia", "dor de cabeça"
    ]

    for s in sintomas_lista:
        if s in texto:
            memoria["sintomas"].add(s)

# ===== PERGUNTAS =====
def perguntar():
    perguntas = [
        "Quando começou?",
        "Está piorando ou melhorando?",
        "A dor é leve, média ou forte?",
        "Isso acontece direto ou vai e volta?",
        "Tem mais algum sintoma?"
    ]

    for p in perguntas:
        if p not in memoria["perguntas"]:
            memoria["perguntas"].append(p)
            return p

    return "Pode me contar mais detalhes?"

# ===== CÁLCULO DE RISCO =====
def calcular_risco():
    pesos = {
        "dor no peito": 5,
        "falta de ar": 5,
        "desmaio": 5,
        "febre": 2,
        "tontura": 2,
        "dor de cabeça": 2,
        "tosse": 1,
        "náusea": 1,
        "vomito": 1,
        "diarreia": 1
    }

    risco = 0
    for s in memoria["sintomas"]:
        risco += pesos.get(s, 0)

    return risco

# ===== RESULTADO FINAL =====
def gerar_resultado():
    risco = calcular_risco()
    sintomas = memoria["sintomas"]

    resposta = "📊 **Resultado da Triagem**\n\n"

    if risco >= 8:
        resposta += "🔴 Alto risco\n"
    elif risco >= 4:
        resposta += "🟡 Médio risco\n"
    else:
        resposta += "🟢 Baixo risco\n"

    resposta += "\n🧠 **Possíveis problemas:**\n"

    if "dor no peito" in sintomas:
        resposta += "- Possível problema cardíaco\n"

    if "falta de ar" in sintomas:
        resposta += "- Possível problema respiratório\n"

    if "febre" in sintomas:
        resposta += "- Possível infecção\n"

    if "náusea" in sintomas or "vomito" in sintomas:
        resposta += "- Problema digestivo\n"

    resposta += "\n👨‍⚕️ **Especialistas indicados:**\n"

    if "dor no peito" in sintomas:
        resposta += "- Cardiologista\n"

    if "falta de ar" in sintomas:
        resposta += "- Pneumologista\n"

    if "náusea" in sintomas or "vomito" in sintomas:
        resposta += "- Gastroenterologista\n"

    resposta += "\n🚨 **Emergência:**\n"

    if risco >= 8:
        resposta += "⚠️ Procure ajuda imediata!\n"
        resposta += "📞 SAMU: 192\n🚒 Bombeiros: 193\n👮 Polícia: 190\n"
    else:
        resposta += "Sem urgência aparente.\n"

    return resposta

# ===== MOSTRAR CHAT =====
for msg, tipo in st.session_state.chat:
    if tipo == "user":
        st.write("👤:", msg)
    else:
        st.write("🤖:", msg)

# ===== INPUT =====
entrada = st.text_input("Digite aqui...")

if entrada and not memoria["finalizado"]:
    st.session_state.chat.append((entrada, "user"))

    detectar(entrada)
    memoria["interacoes"] += 1

    if memoria["interacoes"] < 5:
        resposta = perguntar()
    else:
        resposta = gerar_resultado()
        memoria["finalizado"] = True

    st.session_state.chat.append((resposta, "bot"))
    st.rerun()

# ===== BOTÃO RESET =====
if st.button("🔄 Nova consulta"):
    st.session_state.chat = []
    st.session_state.memoria = {
        "sintomas": set(),
        "perguntas": [],
        "interacoes": 0,
        "finalizado": False
    }
    st.rerun()